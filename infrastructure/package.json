    "destroy": "cdk destroy BwNexusBedrockStack"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.130.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.130.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
