{
  "name": "bw-nexus-bedrock-infrastructure",
  "version": "1.0.0",
  "description": "AWS CDK infrastructure for BW NEXUS Bedrock Agents pipeline",
  "private": true,
  "scripts": {
    "build": "tsc",
    "deploy": "cdk deploy BwNexusBedrockStack --require-approval never",
