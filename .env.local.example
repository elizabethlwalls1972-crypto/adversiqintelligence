# ═══════════════════════════════════════════════════════════════════════════════
# BWGA Intelligence AI - Local Development Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env.local and add your API keys when ready
#
# ═══════════════════════════════════════════════════════════════════════════════

# Optional: Add API keys for local development
# Uncomment and fill in when you want to test with real AI providers

# OpenAI GPT-4
# VITE_OPENAI_API_KEY=[REDACTED_TOKEN]

# Groq (free tier)
# VITE_GROQ_API_KEY=...

# Together.ai (free tier)
# VITE_TOGETHER_API_KEY=...

# Feature Flags
REACT_APP_USE_REAL_AI=true
REACT_APP_USE_REAL_DATA=true
REACT_APP_USE_REAL_BACKEND=false
REACT_APP_SHOW_DEMO_INDICATORS=false
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_AUTH=false

# Development Settings
NODE_ENV=development
VITE_API_BASE_URL=http://localhost:3001/api

# Self-Learning Configuration
VITE_ENABLE_SELF_LEARNING=true
VITE_LEARNING_DATA_PATH=./learning-data
VITE_AUTO_IMPROVE=true
