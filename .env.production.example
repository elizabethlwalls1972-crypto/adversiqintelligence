# ═══════════════════════════════════════════════════════════════════════════════
# BWGA Intelligence AI - PRODUCTION ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your API keys
# NEVER commit .env to source control
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-domain.com

# ═══════════════════════════════════════════════════════════════════════════════
# AI PROVIDERS (Optional - add when ready)
# ═══════════════════════════════════════════════════════════════════════════════

# OpenAI GPT-4
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# Groq (Ultra-Fast LPU)
# Get from: https://console.groq.com
# GROQ_API_KEY=your_groq_api_key_here

# Together.ai (Llama models)
# Get from: https://api.together.xyz
# TOGETHER_API_KEY=your_together_api_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# SEARCH PROVIDERS (Reactive Intelligence)
# ═══════════════════════════════════════════════════════════════════════════════

# Serper (Google Search API)
# Get from: https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

# News API (Real-time News)
# Get from: https://newsapi.org/
NEWS_API_KEY=your_newsapi_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# FINANCIAL DATA PROVIDERS
# ═══════════════════════════════════════════════════════════════════════════════

# Alpha Vantage (Stock/Forex Data)
# Get from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE (Optional - for persistence)
# ═══════════════════════════════════════════════════════════════════════════════

# MongoDB (for storing reports, learning outcomes)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bwnexus

# Redis (for caching)
# REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════════════════════

# JWT Secret (for authentication if implemented)
# JWT_SECRET=your-super-secret-jwt-key-change-this

# Session Secret
# SESSION_SECRET=your-session-secret-change-this
